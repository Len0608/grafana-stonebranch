{
  "__inputs": [{ "name": "DS_STONEBRANCH_UAC", "label": "Stonebranch UAC", "type": "datasource", "pluginId": "libellecov-stonebranchuac-datasource", "pluginName": "Stonebranch UAC" }],
  "__requires": [{ "type": "datasource", "id": "libellecov-stonebranchuac-datasource", "name": "Stonebranch UAC", "version": "1.0.0" }],
  "annotations": { "list": [] },
  "description": "Stonebranch UAC task execution history, launch rates, and SLA adherence",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "sum", "labelFilters": [], "legendFormat": "Total Launched", "metric": "uc_task_instance_launch_total", "refId": "A" }],
      "title": "Total Launched (Lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "sum", "labelFilters": [], "legendFormat": "Monthly Executions", "metric": "uc_monthly_executions", "refId": "A" }],
      "title": "Monthly Executions",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "sum", "labelFilters": [], "legendFormat": "Early Finishes", "metric": "uc_task_instance_early_finish_total", "refId": "A" }],
      "title": "Early Finishes (Lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "sum", "labelFilters": [], "legendFormat": "Late Finishes", "metric": "uc_task_instance_late_finish_total", "refId": "A" }],
      "title": "Late Finishes (Lifetime)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "History Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Finished" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Skipped" }, "properties": [{ "id": "color", "value": { "fixedColor": "gray", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "displayLabels": ["percent"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "pie", "tooltip": { "mode": "multi" } },
      "targets": [{ "aggregate": "sum", "groupBy": "task_instance_status", "labelFilters": [], "legendFormat": "{{task_instance_status}}", "metric": "uc_history_total", "refId": "A" }],
      "title": "History by Status",
      "type": "piechart"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 } } },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "barWidth": 0.85, "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" }, "xTickLabelRotation": -20 },
      "targets": [{ "aggregate": "sum", "groupBy": "task_type", "labelFilters": [], "legendFormat": "{{task_type}}", "metric": "uc_history_total", "refId": "A" }],
      "title": "History by Task Type",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Top Tasks",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "options": { "Success": { "color": "green", "index": 0 }, "Failed": { "color": "red", "index": 1 }, "Finished": { "color": "blue", "index": 2 }, "Skipped": { "color": "gray", "index": 3 } }, "type": "value" }] }] },
          { "matcher": { "id": "byName", "options": "Executions" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "id": 7,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "Executions", "desc": true }], "enablePagination": true },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "{{task_name}}", "metric": "uc_history_total", "refId": "A" }],
      "title": "Task History (Lifetime)",
      "transformations": [
        { "id": "labelsToFields", "options": { "keepLabels": ["task_name", "task_type", "task_instance_status"] } },
        { "id": "merge", "options": {} },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "Value", "desc": true }] } },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "task_name": 0, "task_type": 1, "task_instance_status": 2, "Value": 3 }, "renameByName": { "Value": "Executions", "task_name": "Task Name", "task_type": "Task Type", "task_instance_status": "Status" } } },
        { "id": "limit", "options": { "limitField": 10 } },
        { "id": "transpose", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Field": "Task Name", "1": "Number of Launches", "Executions": "Number of Launches" } } }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 36,
  "tags": ["stonebranch", "uac", "tasks"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "name": "DS_STONEBRANCH_UAC", "options": [], "query": "libellecov-stonebranchuac-datasource", "refresh": 1, "type": "datasource" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "UAC Task Execution",
  "uid": "stonebranch-task-execution",
  "version": 5
}
