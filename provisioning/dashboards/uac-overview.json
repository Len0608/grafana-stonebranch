{
  "__inputs": [
    {
      "name": "DS_STONEBRANCH_UAC",
      "label": "Stonebranch UAC",
      "description": "",
      "type": "datasource",
      "pluginId": "libellecov-stonebranchuac-datasource",
      "pluginName": "Stonebranch UAC"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "libellecov-stonebranchuac-datasource",
      "name": "Stonebranch UAC",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Stonebranch Universal Controller — at-a-glance operational overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Task Instances",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "displayName": "${__field.name}"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Running" },        "properties": [{ "id": "color", "value": { "fixedColor": "green",           "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Waiting" },        "properties": [{ "id": "color", "value": { "fixedColor": "blue",            "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" },         "properties": [{ "id": "color", "value": { "fixedColor": "red",             "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Start Failure" },  "properties": [{ "id": "color", "value": { "fixedColor": "dark-red",        "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Running/Problems" },"properties": [{ "id": "color", "value": { "fixedColor": "orange",         "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Approval Required" },"properties": [{ "id": "color", "value": { "fixedColor": "yellow",        "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Held" },           "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-yellow","mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Undeliverable" },  "properties": [{ "id": "color", "value": { "fixedColor": "dark-orange",     "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "{{task_instance_status}}", "metric": "uc_task_instance_active", "valueFilter": { "op": ">", "value": 0 }, "refId": "A" }],
      "title": "Active Task Instances by Status",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
      "title": "Agents",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 12 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "count", "valueFilter": { "op": "=", "value": 1 }, "labelFilters": [], "legendFormat": "Active Agents", "metric": "uc_agent_status", "refId": "A" }],
      "title": "Active Agents",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "mappings": [] }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 12 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "count", "valueFilter": { "op": "=", "value": 0 }, "labelFilters": [], "legendFormat": "Offline Agents", "metric": "uc_agent_status", "refId": "A" }],
      "title": "Offline Agents",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "Offline" }, "1": { "color": "green", "index": 1, "text": "Active" }, "-1": { "color": "orange", "index": 2, "text": "Unknown" } }, "type": "value" }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "custom": { "displayMode": "color-background" }
        }
      },
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 12 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "Agent Name" }] },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "{{agent_id}}", "metric": "uc_agent_status", "refId": "A" }],
      "title": "Agent Status",
      "transformations": [
        { "id": "labelsToFields", "options": { "keepLabels": ["agent_id"] } },
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "agent_id": "Agent Name", "Value": "Status" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "color": "red", "index": 0, "text": "Disconnected" }, "1": { "color": "green", "index": 1, "text": "Connected" }, "-1": { "color": "orange", "index": 2, "text": "Unknown" } }, "type": "value" }],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "id": 16,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "OMS Status", "metric": "uc_oms_server_status", "refId": "A" }],
      "title": "OMS Server",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "color": "orange", "index": 0, "text": "None" }, "1": { "color": "yellow", "index": 1, "text": "Impaired" }, "2": { "color": "green", "index": 2, "text": "Operational" }, "-1": { "color": "red", "index": 3, "text": "Unknown" } }, "type": "value" }],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 },
      "id": 17,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "OMS Session", "metric": "uc_oms_server_session_status", "refId": "A" }],
      "title": "OMS Session",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["stonebranch", "uac", "overview"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_STONEBRANCH_UAC",
        "options": [],
        "query": "libellecov-stonebranchuac-datasource",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "UAC Overview",
  "uid": "stonebranch-uac-overview",
  "version": 10
}
