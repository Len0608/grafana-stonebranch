{
  "__inputs": [{ "name": "DS_STONEBRANCH_UAC", "label": "Stonebranch UAC", "type": "datasource", "pluginId": "libellecov-stonebranchuac-datasource", "pluginName": "Stonebranch UAC" }],
  "__requires": [{ "type": "datasource", "id": "libellecov-stonebranchuac-datasource", "name": "Stonebranch UAC", "version": "1.0.0" }],
  "annotations": { "list": [] },
  "description": "Stonebranch UAC JVM internals, DB connection pools, and process health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "JVM Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "aggregate": "none", "labelFilters": [{ "key": "area", "op": "=", "value": "heap" }], "legendFormat": "Heap Used", "metric": "jvm_memory_used_bytes", "refId": "A" },
        { "aggregate": "none", "labelFilters": [{ "key": "area", "op": "=", "value": "heap" }], "legendFormat": "Heap Committed", "metric": "jvm_memory_committed_bytes", "refId": "B" },
        { "aggregate": "none", "labelFilters": [{ "key": "area", "op": "=", "value": "heap" }], "legendFormat": "Heap Max", "metric": "jvm_memory_max_bytes", "refId": "C" }
      ],
      "title": "Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "aggregate": "none", "labelFilters": [{ "key": "area", "op": "=", "value": "nonheap" }], "legendFormat": "Non-Heap Used", "metric": "jvm_memory_used_bytes", "refId": "A" },
        { "aggregate": "none", "labelFilters": [{ "key": "area", "op": "=", "value": "nonheap" }], "legendFormat": "Non-Heap Committed", "metric": "jvm_memory_committed_bytes", "refId": "B" }
      ],
      "title": "Non-Heap Memory",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "GC & Threads",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "{{gc}}", "metric": "jvm_gc_collection_seconds_sum", "refId": "A" }],
      "title": "GC Collection Time (Total)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "orange", "value": 100 }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "Threads", "metric": "jvm_threads_current", "refId": "A" }],
      "title": "Current Threads",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "mappings": [{ "options": { "0": { "color": "green", "index": 0, "text": "None" } }, "type": "value" }] } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 10 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "Deadlocked", "metric": "jvm_threads_deadlocked", "refId": "A" }],
      "title": "Deadlocked Threads",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 } } },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "id": 6,
      "options": { "barWidth": 0.85, "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "{{state}}", "metric": "jvm_threads_state", "refId": "A" }],
      "title": "Thread States",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Database Connection Pools",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "options": { "barWidth": 0.85, "groupWidth": 0.7, "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" }, "xTickLabelRotation": 0 },
      "targets": [
        { "aggregate": "none", "labelFilters": [], "legendFormat": "Active – {{pool}}", "metric": "uc_database_connection_pool_active", "refId": "A" },
        { "aggregate": "none", "labelFilters": [], "legendFormat": "Idle – {{pool}}", "metric": "uc_database_connection_pool_idle", "refId": "B" },
        { "aggregate": "none", "labelFilters": [], "legendFormat": "Max – {{pool}}", "metric": "uc_database_connection_pool_max", "refId": "C" }
      ],
      "title": "DB Connection Pool Usage",
      "type": "barchart"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "aggregate": "none", "labelFilters": [], "legendFormat": "Allocated – {{pool}}", "metric": "uc_database_connection_pool_allocated", "refId": "A" },
        { "aggregate": "none", "labelFilters": [], "legendFormat": "Max – {{pool}}", "metric": "uc_database_connection_pool_max", "refId": "B" }
      ],
      "title": "DB Pool Allocation",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Process",
      "type": "row"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 900 }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "id": 9,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "Open FDs", "metric": "process_open_fds", "refId": "A" }],
      "title": "Open File Descriptors",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "RSS", "metric": "process_resident_memory_bytes", "refId": "A" }],
      "title": "Resident Memory",
      "type": "stat"
    },
    {
      "datasource": { "type": "libellecov-stonebranchuac-datasource", "uid": "${DS_STONEBRANCH_UAC}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 28 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "aggregate": "none", "labelFilters": [], "legendFormat": "CPU Time", "metric": "process_cpu_seconds_total", "refId": "A" }],
      "title": "Total CPU Time",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["stonebranch", "uac", "jvm", "infrastructure"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "name": "DS_STONEBRANCH_UAC", "options": [], "query": "libellecov-stonebranchuac-datasource", "refresh": 1, "type": "datasource" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "UAC JVM & Infrastructure",
  "uid": "stonebranch-jvm-health",
  "version": 1
